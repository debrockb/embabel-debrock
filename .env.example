# ─── M.A.T.O.E Environment Variables ─────────────────────────────────────────

# LLM API Keys (optional — leave blank if using only local LLMs)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Local LLM endpoints (set to your NAS LAN IP if running LM Studio/Ollama)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
OLLAMA_BASE_URL=http://localhost:11434

# Admin security (required for production — protects prompt/target mutation)
MATOE_ADMIN_TOKEN=change-me-to-a-secure-token

# CORS origins (frontend URL — adjust if running on a different port)
MATOE_CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Browser service
BROWSER_SERVICE_ENABLED=true
BROWSER_DEFAULT_MODEL=anthropic/claude-3-5-sonnet-20241022
BROWSER_MAX_CONCURRENT=1

# Database (only needed for Docker — SQLite is default for local dev)
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/matoe
# SPRING_DATASOURCE_USERNAME=matoe_user
# SPRING_DATASOURCE_PASSWORD=matoe_password
# POSTGRES_PASSWORD=matoe_password
